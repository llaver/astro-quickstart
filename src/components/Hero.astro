---
// Hero section - Clean, professional design
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">
      <span class="title-text">Dimensional Mayan Tribe</span>
    </h1>
    <p class="hero-subtitle">Bringing the Best of Psytrance to Texas</p>
    <p class="hero-description">
      We are a collective of artists, musicians, and creatives dedicated to exploring the intersection of psychedelia, technology, and creativity. Join us on our journey as we push the boundaries of art and music.
    </p>
    <div class="hero-buttons">
      <a href={`${base}events`} class="btn btn-primary">
        <span>View Events</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
      <a href={`${base}blog`} class="btn btn-secondary">
        <span>Read Blog</span>
      </a>
    </div>
    <div class="hero-socials">
      <a href="https://www.facebook.com/dimensionalmayantribe" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="social-icon">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
        </svg>
      </a>
      <a href="https://www.instagram.com/dimensional_mayan_tribe/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="social-icon ig-icon">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8A4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>
    </div>

    <!-- Tech stack badges -->
    <!-- <div class="tech-stack">
      <span class="tech-badge">TypeScript</span>
      <span class="tech-badge">React</span>
      <span class="tech-badge">Three.js</span>
      <span class="tech-badge">Astro</span>
    </div> -->
  </div>

  <!-- Decorative elements -->
  <div class="hero-decoration">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>
</section>

<style>
  .hero {
    margin-top: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 2rem;
  }

  .hero-content {
    text-align: center;
    z-index: 10;
    max-width: 800px;
    animation: fadeInUp 0.8s ease-out;
  }

  .greeting {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 12vw, 7rem);
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .hero-socials {
    display: flex;
    justify-content: center;;
    margin-top: 2rem;
    max-height: 4rem;
  }

  .social-button {
    /* flex-grow: 1; */
    cursor: pointer;
    color: var(--color-accent-purple);
  }
  .social-button:hover {
    /* flex-grow: 1; */
    color: var(--color-primary);
  }

  .social-icon {
    width: 64px;
    height: 64px;
    margin: 0 2rem;
  }

  .ig-icon {
    margin-left: 1rem;
  }

  .title-text {
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-primary) 50%, var(--color-accent-purple) 100%);
    background-size: 200% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientFlow 4s ease infinite;
  }

  @keyframes gradientFlow {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .hero-subtitle {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--color-text);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .hero-description {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    color: var(--color-text-dim);
    margin-bottom: 2.5rem;
    line-height: 1.7;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-body);
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--color-accent-purple);
    color: white;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
  }

  .btn-primary:hover {
    background: var(--color-primary);
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.5);
  }

  .btn-primary svg {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover svg {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: rgba(59, 130, 246, 0.1);
    border-color: var(--color-primary);
  }

  .tech-stack {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tech-badge {
    padding: 0.5rem 1rem;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    font-size: 0.875rem;
    color: var(--color-text-dim);
    transition: all 0.2s ease;
  }

  .tech-badge:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* Decorative glows */
  .hero-decoration {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
  }

  .glow-1 {
    width: 200px;
    height: 200px;
    background: var(--color-primary);
    top: 10%;
    left: 10%;
    animation: float 8s ease-in-out infinite;
  }

  .glow-2 {
    width: 300px;
    height: 300px;
    background: var(--color-accent-purple);
    bottom: 20%;
    right: 10%;
    animation: float 6s ease-in-out infinite reverse;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(20px, -20px);
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .title-text {
      animation: none;
    }
    .glow-1, .glow-2 {
      animation: none;
    }
    .hero-content {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .hero-buttons {
      flex-direction: column;
      align-items: center;
    }

    .hero-socials {
      max-height: 4rem;
    }

    .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>
