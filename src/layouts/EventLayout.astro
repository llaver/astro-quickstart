---
import BaseLayout from './BaseLayout.astro';
import ThreeBackground from '../components/ThreeBackground.astro';
import Navigation from '../components/Navigation.astro';

interface Props {
  title: string;
  description: string;
  image?: string | undefined;
  dates?: Date[] | undefined;
  links?: { label: string; url: string }[] | undefined;
  tags?: string[] | undefined;
  featured?: boolean | undefined;
}

const base = import.meta.env.BASE_URL;
const { title, description, image, dates, links, tags } = Astro.props;
const imageSrc = image?.startsWith('/') ? `${base}${image.slice(1)}` : image;


const formattedDates = dates?.map((date) => date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
}));

---

<BaseLayout title={`DMT - Event - ${title}`} description={description}>
  <ThreeBackground />
  <Navigation />

  <article class="event-page">
    <div class="container">
      <header class="event-header">
        <a href={`${base}events`} class="back-link">← Back to Events</a>
        <h1 class="event-title shimmer-text">{title}</h1>
        <div class="event-meta">
          {formattedDates && formattedDates.length > 0 && (
            <div class="event-dates">
              {formattedDates && formattedDates[0] && (
                <time class="event-date">
                  {formattedDates[0]}
                </time>
              )}
              {formattedDates && formattedDates[1] && (
                <time class="event-date">
                  {" - "}{formattedDates[1]}
                </time>
              )}
            </div>
          )}
        </div>
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="event-content">
              <slot name="image">
                {image && (
                  <div class="event-image" onclick=`window.location.href='${imageSrc}';`>
                    <img src={imageSrc} alt={title} loading="lazy" />
                  </div>
                )}
        <slot />
        <div class="event-links">
          {links && links[0] && (
            <a href={links[0].url}  class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
              {links[0].label}
            </a>
          )}
          {links && links[1] && (
            <a href={links[1].url}  class="btn btn-secondary" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
              {links[1].label}
            </a>
          )}
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .event-page {
    min-height: 100vh;
    padding: 7rem 2rem 5rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .event-header {
    margin-bottom: 2rem;
    animation: fadeInDown 1s ease-out;
  }

  .featured-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent-purple));
    border-radius: 0.25rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    width: fit-content;
  }

  .back-link {
    display: inline-block;
    color: var(--color-accent-purple);
    text-decoration: none;
    margin-bottom: 1rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .back-link:hover {
    transform: translateX(-5px);
    color: var(--color-accent-pink);
  }

  .event-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .event-meta {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }

  .event-date {
    color: var(--color-accent-purple);
    font-weight: 500;
  }


  .event-image {
    width: 100%;
    aspect-ratio: 17 / 9;
    margin-bottom: 1.25rem;
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: pointer;
    background: var(--color-bg-darker);
  }

  .event-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.3s ease;
  }


  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    font-family: var(--font-body);
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
    margin-right: 1rem;
  }

  .btn-primary {
    background: var(--color-accent-purple);
    color: white;
    box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
  }

  .btn-primary:hover {
    background: var(--color-primary);
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.5);
  }

  .btn-primary svg {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover svg {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: rgba(59, 130, 246, 0.1);
    border-color: var(--color-primary);
  }

  .event-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: start;
    margin-bottom: 1.25rem;
  }

  .event-updated {
    color: var(--color-text-dim);
  }

  .event-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-accent-purple);
  }

  .event-content {
    background: var(--color-bg-card);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 1rem;
    padding: 2rem;
    animation: fadeInUp 1s ease-out 0.2s backwards;
  }

  .event-content :global(h1),
  .event-content :global(h2),
  .event-content :global(h3),
  .event-content :global(h4) {
    color: var(--color-text);
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .event-content :global(h1) {
    font-size: 1.9rem;
  }

  .event-content :global(h2) {
    font-size: 1.75rem;
    background: linear-gradient(135deg, var(--color-accent-purple), var(--color-accent-pink));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .event-content :global(h3) {
    font-size: 1.5rem;
  }

  .event-content :global(p) {
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: var(--color-text-dim);
  }

  .event-content :global(a) {
    /* color: var(--color-accent-purple); */
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .event-content :global(code) {
    background: rgba(168, 85, 247, 0.1);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-family: 'Courier New', monospace;
    font-size: 0.9em;
    color: var(--color-accent-purple);
  }

  .event-content :global(pre) {
    background: var(--color-bg-darker);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 0.5rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .event-content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-text);
  }

  .event-content :global(ul),
  .event-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 2rem;
    color: var(--color-text-dim);
  }

  .event-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .event-content :global(blockquote) {
    border-left: 4px solid var(--color-accent-purple);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-dim);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(85, 247, 93, 0.3);
    border-radius: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-primary);
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .event-content {
      padding: 2rem 1.5rem;
    }
  }
</style>
