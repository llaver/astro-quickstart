---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThreeBackground from '../../components/ThreeBackground.astro';
import Navigation from '../../components/Navigation.astro';
import EventCard from '../../components/EventCard.astro';

const sortEvents = (a: any, b: any) => {
  if(!a.data.dates || !b.data.dates || !a.data.dates[0] || !b.data.dates[0]) {
    return 0;
  } else {
    return b.data.dates[0].valueOf() - a.data.dates[0].valueOf()
  }
};

const allEvents = await getCollection('events');
const featuredEvents = allEvents.filter(e => e.data.featured).sort(sortEvents);
const otherEvents = allEvents.filter(e => !e.data.featured).sort(sortEvents);
---

<BaseLayout
  title="DMT - Events"
  description="Upcoming and Past Dimensional Mayan Tribe Events"
>
  <ThreeBackground />
  <Navigation />

  <main class="events-page">
    <div class="container">
      <header class="events-header">
        <h1 class="page-title">Events</h1>
        <p class="page-subtitle">
          Upcoming and Past Dimensional Mayan Tribe Events
        </p>
      </header>

      {featuredEvents.length > 0 && (
        <section class="featured-section">
          <h2 class="section-title">Upcoming Events</h2>
          <div class="events-grid featured-grid">
            {featuredEvents.map((event) => (
              <EventCard
                title={event.data.title}
                description={event.data.description}
                image={event.data.image}
                dates={event.data.dates}
                links={event.data.links}
                tags={event.data.tags}
                slug={event.id}
                featured={true}
              />
            ))}
          </div>
        </section>
      )}

      {otherEvents.length > 0 && (
        <section class="other-events">
          <h2 class="section-title">Previous Events</h2>
          <div class="events-grid">
            {otherEvents.map((event) => (
              <EventCard
                title={event.data.title}
                description={event.data.description}
                image={event.data.image}
                dates={event.data.dates}
                links={event.data.links}
                tags={event.data.tags}
                slug={event.id}
                featured={false}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .events-page {
    min-height: 100vh;
    padding: calc(var(--nav-height) + 2rem) 2rem 5rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .events-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-dim);
    max-width: 500px;
    margin: 0 auto;
  }

  .other-events {
    margin-top: 3rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .featured-grid {
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
  }

  @media (max-width: 768px) {
    .events-page {
      padding-top: calc(var(--nav-height) + 1rem);
    }

    .events-grid,
    .featured-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
